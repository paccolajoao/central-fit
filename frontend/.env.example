# URL do backend Laravel (usada pelo axios no browser e pelo fetch server-side)
NEXT_PUBLIC_API_URL=http://localhost:8000

# URL do próprio frontend — usada como Origin/Referer no fetch server-side
# para o Sanctum reconhecer a requisição como "stateful".
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Nome do cookie de sessão do Laravel (precisa bater com SESSION_COOKIE do backend).
SESSION_COOKIE_NAME=central_fit_session
